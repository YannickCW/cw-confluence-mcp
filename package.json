{
  "name": "@cloudwise/cw-confluence-mcp",
  "version": "0.1.0",
  "description": "Local MCP server giving Claude Code structured, authenticated access to Confluence Cloud.",
  "author": "Yannick Wensink",
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "confluence",
    "atlassian",
    "cloudwise"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YannickCW/cw-confluence-mcp.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "cw-confluence-mcp": "./bin/cw-confluence-mcp.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://pkgs.dev.azure.com/heutinkict/MOO/_packaging/MOO.Shared/npm/registry/"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run --dir tests/unit",
    "test:integration": "vitest run --dir tests/integration",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "sync-version": "node scripts/sync-version.mjs",
    "prebuild": "npm run sync-version",
    "prepack": "npm run build",
    "prepublishOnly": "npm run lint && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@napi-rs/keyring": "^1.1.7",
    "commander": "^12.1.0",
    "prompts": "^2.4.2",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/prompts": "^2.4.9",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^8.57.0",
    "msw": "^2.4.9",
    "prettier": "^3.3.3",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.1"
  }
}
